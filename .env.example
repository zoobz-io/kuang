# =============================================================================
# Application
# =============================================================================
APP_PORT=8080

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=kuang
APP_DB_USER=kuang
APP_DB_PASSWORD=kuang
APP_DB_SSLMODE=disable

# =============================================================================
# Cache (Redis)
# =============================================================================
APP_REDIS_ADDR=localhost:6379

# =============================================================================
# Storage (MinIO/S3)
# =============================================================================
APP_STORAGE_ENDPOINT=localhost:9000
APP_STORAGE_ACCESS_KEY=kuang
APP_STORAGE_SECRET_KEY=kuangdev
APP_STORAGE_BUCKET=kuang
APP_STORAGE_USE_SSL=false

# =============================================================================
# Security
# =============================================================================
APP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
APP_CA_CERT_PATH=certs/ca.pem
APP_CERT_PATH=certs/server.pem
APP_KEY_PATH=certs/server-key.pem
APP_CRYPTO_ALGO=ed25519
APP_REQUIRE_MTLS=true

# =============================================================================
# Observability (OTEL)
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=kuang
